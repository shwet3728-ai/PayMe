# ====================================

# APP

# ====================================

NODE_ENV=development
PORT=3001
CORS_ORIGIN="http://localhost:3000"

# ====================================

# DATABASE

# ====================================

DATABASE_URL="postgresql://postgres:password@localhost:5432/payme"

# ====================================

# JWT

# ====================================

JWT_SECRET="replace_with_secure_secret"
JWT_REFRESH_SECRET="replace_with_secure_refresh_secret"

JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# In development, OTP is returned by the API so you can test without SMS.
# In production, OTP is hidden unless OTP_DEBUG=true.
OTP_DEBUG="false"

# ====================================

# RAZORPAY

# ====================================

RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""

# ====================================

# FIREBASE

# ====================================

FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""

# ====================================

# FRONTEND URLS

# ====================================

CUSTOMER_WEB_URL="http://localhost:3000"
SHOP_DASHBOARD_URL="http://localhost:3002"
ADMIN_PANEL_URL="http://localhost:3003"
